IF VAR $APPLICATION[2] "V9*"
PRINT "LOAD MK_BG APPLICAITION"
PRINT "Ver 9"
PRINT "LOAD A_MK_RUNBG_"
PCLOAD A_MK_RUNBG_.pc
PRINT "LOAD DICT"
KCL LOAD DICT tpmkbgch MKBG CHINESE
KCL LOAD VARS mkbgch CONVERT
KCL LOAD DICT tpmkbgeg MKBG ENGLIS
KCL LOAD VARS mkbg CONVERT
PRINT "INSTALL DONE"
ELSE
PRINT "Controller Version isn't V9"
ENDIF
